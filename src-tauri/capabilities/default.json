{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for the MDXera ERP main window",
  "windows": ["main", "window-*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "core:window:allow-center",
    "core:window:allow-set-title",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "core:window:allow-show",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-save",
    "store:allow-load",
    "store:allow-keys",
    "store:allow-has",
    "store:allow-entries",
    "shell:allow-open",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
