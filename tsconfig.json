
{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@core/services/storageService":         ["./services/storageService"],
      "@core/services/geminiService":          ["./services/geminiService"],
      "@core/services/supplierService":        ["./services/supplierService"],
      "@core/services/companyDefaultsService": ["./services/companyDefaultsService"],
      "@core/*":    ["./src/core/*"],
      "@modules/*": ["./src/modules/*"],
      "@app/*":     ["./src/app/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "supabase/functions",
    ".claude",
    "services/powersync.ts",
    "src/app/App.tsx",
    "src/app/Router.tsx",
    "src/core/hooks/usePermissions.ts",
    "src/modules/inventory/services/inventoryService.ts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
